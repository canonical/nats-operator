{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":disableDependencyDashboard",
        ":automergeDigest",
        ":automergePatch",
        ":automergeMinor",
        ":rebaseStalePrs",
        ":semanticCommits",
        ":semanticCommitScope(deps)",
        "docker:pinDigests",
        "helpers:pinGitHubActionDigestsToSemver",
        "customManagers:dockerfileVersions",
        "group:allNonMajor"
    ],
    "minimumReleaseAge": "90 days",
    "minimumReleaseAgeBehaviour": "timestamp-optional",
    "prCreation": "not-pending",
    "automergeType": "branch",
    "packageRules": [
        {
            "groupName": "github actions",
            "matchManagers": [
                "github-actions"
            ],
            "automerge": true,
            "schedule": [
                "on monday"
            ]
        },
        {
            "groupName": "testing deps",
            "matchFileNames": [
                "tox.ini"
            ],
            "matchUpdateTypes": [
                "major",
                "minor",
                "patch",
                "pin",
                "digest"
            ],
            "automerge": true,
            "schedule": [
                "on monday"
            ]
        },
        {
            "groupName": "renovate packages",
            "matchSourceUrls": [
                "https://github.com/renovatebot/{/,}**"
            ],
            "matchUpdateTypes": [
                "major",
                "minor",
                "patch",
                "pin",
                "digest"
            ],
            "automerge": true,
            "schedule": [
                "on monday"
            ]
        },
        {
             "matchPackageNames": ["rpds-py"],
             "allowedVersions": "^0.24.0"
        }
    ],
    "customManagers": [
        {
            "customType": "regex",
            "managerFilePatterns": [
                "tox.ini"
            ],
            "matchStrings": [
                "# renovate: datasource=(?<datasource>\\S+)\n\\s+(?<depName>.*?)==(?<currentValue>.*?)\\n"
            ]
        }
    ]
}
